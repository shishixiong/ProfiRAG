# ProfiRAG Configuration
# Copy this file to .env and fill in your values

# ==================== OpenAI Configuration ====================
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=
# For custom endpoints (e.g., Azure, local proxy): OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_EMBEDDING_API_KEY=sk-xxx
OPENAI_EMBEDDING_BASE_URL=
# Fallback to OPENAI_BASE_URL if not set
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536
OPENAI_LLM_MODEL=gpt-4-turbo
OPENAI_LLM_TEMPERATURE=0.0

# ==================== Embedding Provider Configuration ====================
# Provider: openai (API-based) or fastembed (local)
PROFIRAG_EMBEDDING_PROVIDER=openai

# FastEmbed Configuration (only used when PROFIRAG_EMBEDDING_PROVIDER=fastembed)
# Model name - dimension auto-detected for known models
PROFIRAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Optional: override dimension (defaults to auto-detected based on model)
PROFIRAG_EMBEDDING_DIMENSION=
# Optional: custom cache directory for model files (defaults to ~/.cache/fastembed)
PROFIRAG_EMBEDDING_CACHE_DIR=

# ==================== Storage Configuration ====================
# Storage type: qdrant, local, postgres
PROFIRAG_STORAGE_TYPE=qdrant

# ==================== Qdrant Configuration ====================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=profirag
# For Qdrant Cloud: QDRANT_URL=https://xxx.qdrant.io

# ==================== PostgreSQL Configuration ====================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=profirag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ==================== Local Storage Configuration ====================
LOCAL_STORAGE_PATH=./storage
LOCAL_COLLECTION_NAME=default

# ==================== Retrieval Configuration ====================
PROFIRAG_TOP_K=10
PROFIRAG_ALPHA=0.5
PROFIRAG_RETRIEVE_INDEX_MODE=hybrid  # hybrid (dense+BM25), sparse (BM25 only), vector (dense only)
PROFIRAG_USE_HYBRID=true
PROFIRAG_USE_BM25=true

# ==================== Chunking Configuration ====================
# Splitter type: sentence, token, semantic, chinese
PROFIRAG_SPLITTER_TYPE=sentence
PROFIRAG_CHUNK_SIZE=512
PROFIRAG_CHUNK_OVERLAP=50
# Language: en, zh (auto-selects Chinese splitter for zh)
PROFIRAG_LANGUAGE=en

# ==================== Reranking Configuration ====================
PROFIRAG_RERANK_ENABLED=true
PROFIRAG_RERANK_PROVIDER=local  # local (CrossEncoder), cohere, dashscope
PROFIRAG_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
PROFIRAG_RERANK_TOP_N=5
PROFIRAG_RERANK_TIMEOUT=30

# For API-based reranking (required when provider != local)
# PROFIRAG_RERANK_API_KEY=your-api-key
# PROFIRAG_RERANK_BASE_URL=https://api.cohere.ai
# DashScope example: PROFIRAG_RERANK_BASE_URL=https://dashscope.aliyuncs.com

# ==================== Pre-Retrieval Configuration ====================
PROFIRAG_USE_HYDE=false
PROFIRAG_USE_REWRITE=false
PROFIRAG_MULTI_QUERY=false
